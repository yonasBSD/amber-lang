main {
    // Verify shellname returns a valid value
    const name = shellname()
    if name != "bash" and name != "zsh" and name != "ksh" {
        echo("Failed")
    }
    
    // Verify the version looks reasonable (major version 1-9)
    // ksh93 (what i'm using) starts with 1
    const version = shellversion()
    if version[0] >= 1 and version[0] <= 9 {
        echo("Succeeded")
    } else {
        echo("Version check failed")
    }
}
